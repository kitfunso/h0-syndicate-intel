# ---- Google Vertex AI (the agent brain + embeddings) ----
# H0 compliance: the running app MUST use Google Cloud AI. We route Gemini through
# Vertex AI (not the AI Studio endpoint) so "Google Cloud AI tools" is unambiguous.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Local dev auth: path to a service-account key, OR run `gcloud auth application-default login`.
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json
# Model IDs. Set GEMINI_MODEL to the current Gemini 3 flash ID in your Vertex Model Garden.
GEMINI_MODEL=gemini-3-flash
EMBED_MODEL=gemini-embedding-001
EMBED_DIM=768

# ---- Aurora PostgreSQL (provisioned via the Vercel AWS Marketplace integration) ----
# OWNER connection: used by migrations + seed only. Full privileges.
DATABASE_URL=postgres://owner:password@host:5432/syndicate
# READ-ONLY connection: used by /api/ask query execution. SELECT-only role (see 0003_roles.sql).
# In production on Vercel, the native integration injects credentials via OIDC + RDS IAM;
# locally, point this at the read-only role created by the migration.
READONLY_DATABASE_URL=postgres://app_readonly:password@host:5432/syndicate

# ---- Query guardrails ----
QUERY_ROW_LIMIT=200
STATEMENT_TIMEOUT_MS=5000
