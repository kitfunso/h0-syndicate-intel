# ---- AWS Bedrock (the agent brain + embeddings), via the Vercel AI SDK ----
# H0 is an AWS + Vercel hackathon, so the LLM runs on Bedrock (same AWS account as
# Aurora, one cloud). First enable model access for Claude + Titan in the Bedrock
# console. The Bedrock provider reads the standard AWS credential chain.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
BEDROCK_CHAT_MODEL=us.anthropic.claude-sonnet-4-6
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
EMBED_DIM=1024   # Titan v2 default; must match vector(1024) in 0002_schema.sql

# ---- Aurora PostgreSQL (provisioned via the Vercel AWS Marketplace integration) ----
# OWNER connection: migrations + seed only.
DATABASE_URL=postgres://owner:password@host:5432/syndicate
# READ-ONLY connection: the /api/ask query path. SELECT-only role (see 0003_roles.sql).
READONLY_DATABASE_URL=postgres://app_readonly:password@host:5432/syndicate

# ---- Query guardrails ----
QUERY_ROW_LIMIT=200
STATEMENT_TIMEOUT_MS=5000
